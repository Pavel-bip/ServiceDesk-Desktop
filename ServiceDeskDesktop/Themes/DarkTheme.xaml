<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <SolidColorBrush x:Key="BackgroundBrush" Color="#1E1E2E"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="#2D2D3F"/>
    <SolidColorBrush x:Key="SurfaceAltBrush" Color="#3A3A50"/>
    <SolidColorBrush x:Key="PrimaryBrush" Color="#9B30FF"/>
    <SolidColorBrush x:Key="PrimaryDarkBrush" Color="#7B1FA2"/>
    <SolidColorBrush x:Key="PrimaryLightBrush" Color="#B388FF"/>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#E8E0FF"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#B0A0D0"/>
    <SolidColorBrush x:Key="TextOnPrimaryBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="BorderBrush" Color="#9B30FF"/>
    <SolidColorBrush x:Key="RowBrush" Color="#2D2D3F"/>
    <SolidColorBrush x:Key="RowAltBrush" Color="#252538"/>
    <SolidColorBrush x:Key="StatusBarBrush" Color="#3A3A50"/>
    <SolidColorBrush x:Key="HoverBrush" Color="#7B1FA2"/>
    <SolidColorBrush x:Key="HoverLightBrush" Color="#9575CD"/>
    <SolidColorBrush x:Key="ExitBrush" Color="#FF6B6B"/>
    <SolidColorBrush x:Key="ExitHoverBrush" Color="#E53935"/>

    <!-- Заголовки таблиц -->
    <Style TargetType="DataGridColumnHeader">
        <Setter Property="Background" Value="#3A3A50"/>
        <Setter Property="Foreground" Value="#E8E0FF"/>
        <Setter Property="FontWeight" Value="Bold"/>
    </Style>

    <!-- Ячейки таблиц -->
    <Style TargetType="DataGridCell">
        <Setter Property="Foreground" Value="#E8E0FF"/>
    </Style>
    <!-- Выделенная строка -->
    <Style TargetType="DataGridRow">
        <Setter Property="Background" Value="Transparent"/>
    </Style>

    <!-- Цвет выделения -->
    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#7B1FA2"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#6A0DAD"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="#E8E0FF"/>

</ResourceDictionary>