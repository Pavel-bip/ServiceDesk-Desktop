<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <SolidColorBrush x:Key="BackgroundBrush" Color="#F5F0FF"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="SurfaceAltBrush" Color="#E8E0F0"/>
    <SolidColorBrush x:Key="PrimaryBrush" Color="#9B30FF"/>
    <SolidColorBrush x:Key="PrimaryDarkBrush" Color="#6A0DAD"/>
    <SolidColorBrush x:Key="PrimaryLightBrush" Color="#B388FF"/>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#4B0082"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#2D004D"/>
    <SolidColorBrush x:Key="TextOnPrimaryBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="BorderBrush" Color="#9B30FF"/>
    <SolidColorBrush x:Key="RowBrush" Color="#FDFAFF"/>
    <SolidColorBrush x:Key="RowAltBrush" Color="#F5F0FF"/>
    <SolidColorBrush x:Key="StatusBarBrush" Color="#E8E0F0"/>
    <SolidColorBrush x:Key="HoverBrush" Color="#7B1FA2"/>
    <SolidColorBrush x:Key="HoverLightBrush" Color="#9575CD"/>
    <SolidColorBrush x:Key="ExitBrush" Color="#FF6B6B"/>
    <SolidColorBrush x:Key="ExitHoverBrush" Color="#E53935"/>

    <!-- Заголовки таблиц -->
    <Style TargetType="DataGridColumnHeader">
        <Setter Property="Background" Value="#E8E0F0"/>
        <Setter Property="Foreground" Value="#4B0082"/>
        <Setter Property="FontWeight" Value="Bold"/>
    </Style>

    <!-- Ячейки таблиц -->
    <Style TargetType="DataGridCell">
        <Setter Property="Foreground" Value="#2D004D"/>
    </Style>

</ResourceDictionary>