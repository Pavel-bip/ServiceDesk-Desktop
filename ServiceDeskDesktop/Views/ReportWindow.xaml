<Window x:Class="ServiceDeskDesktop.Views.ReportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Экспорт отчёта" Height="350" Width="450"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{DynamicResource BackgroundBrush}" Icon="/Views/upscalemedia-transformed.png">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="НАСТРОЙКА ОТЧЁТА" FontSize="16" FontWeight="Bold" 
                   Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center" Margin="0,0,0,20"/>

        <StackPanel Grid.Row="1">
            <TextBlock Text="Период:" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,5"/>
            <ComboBox x:Name="PeriodCombo" Height="28" Margin="0,0,0,15"
                      BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                      Background="White" Foreground="#2D004D">
                <ComboBoxItem Content="За сегодня" Tag="day"/>
                <ComboBoxItem Content="За неделю" Tag="week" IsSelected="True"/>
                <ComboBoxItem Content="За месяц" Tag="month"/>
                <ComboBoxItem Content="За всё время" Tag="all"/>
            </ComboBox>

            <TextBlock Text="Группировка для отчёта:" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,10,0,5"/>
            <CheckBox x:Name="GroupByStatus" Content="По статусам" IsChecked="True" 
                      Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,5"/>
            <CheckBox x:Name="GroupByType" Content="По типам оборудования" IsChecked="True" 
                      Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,5"/>
            <CheckBox x:Name="GroupByDistrict" Content="По районам" IsChecked="True" 
                      Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,5"/>
            <CheckBox x:Name="GroupByPriority" Content="По приоритетам" IsChecked="True" 
          Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,5"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="📊 Excel" Width="130" Height="35" Margin="0,0,10,0"
                    Click="GenerateExcel_Click"
                    Foreground="White" FontWeight="Bold" FontSize="13"
                    BorderThickness="0" Cursor="Hand">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="#9B30FF"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Bd" Background="{TemplateBinding Background}" 
                                            CornerRadius="8" Padding="10,5">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#7B1FA2"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
            </Button>

            <Button Content="📝 Word" Width="130" Height="35"
                    Click="GenerateWord_Click"
                    Foreground="White" FontWeight="Bold" FontSize="13"
                    BorderThickness="0" Cursor="Hand">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="#B388FF"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Bd" Background="{TemplateBinding Background}" 
                                            CornerRadius="8" Padding="10,5">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#9575CD"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
            </Button>
        </StackPanel>
    </Grid>
</Window>