<Window x:Class="ServiceDeskDesktop.Views.FirstRunWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Создание администратора" Height="380" Width="450"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="{DynamicResource BackgroundBrush}" Icon="/Views/upscalemedia-transformed.png">

    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="📡 ДОБРО ПОЖАЛОВАТЬ!" FontSize="20" FontWeight="Bold" 
                       Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center"/>
            <TextBlock Text="Для начала работы создайте учётную запись администратора" 
                       FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center" Margin="0,5,0,0"/>
        </StackPanel>

        <StackPanel Grid.Row="1">
            <TextBlock Text="Email администратора:" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,5,0,0"/>
            <TextBox x:Name="EmailTextBox" Height="30" Margin="0,0,0,10"
                     BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                     Background="{DynamicResource SurfaceBrush}" Foreground="{DynamicResource TextPrimaryBrush}"/>

            <TextBlock Text="Пароль (мин. 6 символов):" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,5,0,0"/>
            <PasswordBox x:Name="PasswordBox" Height="30" Margin="0,0,0,10"
                         BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                         Background="{DynamicResource SurfaceBrush}" Foreground="{DynamicResource TextPrimaryBrush}"/>

            <TextBlock Text="Подтвердите пароль:" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,5,0,0"/>
            <PasswordBox x:Name="ConfirmPasswordBox" Height="30" Margin="0,0,0,10"
                         BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                         Background="{DynamicResource SurfaceBrush}" Foreground="{DynamicResource TextPrimaryBrush}"/>
        </StackPanel>

        <Button Grid.Row="2" Content="Создать администратора" Height="38"
                Click="CreateAdmin_Click"
                Foreground="White" FontWeight="Bold" FontSize="14"
                BorderThickness="0" Cursor="Hand">
            <Button.Style>
                <Style TargetType="Button">
                    <Setter Property="Background" Value="#9B30FF"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" Background="{TemplateBinding Background}" 
                                        CornerRadius="8" Padding="10,5">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#7B1FA2"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </Button.Style>
        </Button>
    </Grid>
</Window>