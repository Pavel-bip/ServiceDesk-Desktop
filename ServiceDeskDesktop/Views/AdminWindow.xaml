<Window x:Class="ServiceDeskDesktop.Views.AdminWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:ServiceDeskDesktop.Converters"
        Title="Панель администратора" Height="550" Width="850"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{DynamicResource BackgroundBrush}" Icon="/Views/upscalemedia-transformed.png">

    <Window.Resources>
        <converters:BlockedToStatusConverter x:Key="BlockedToStatusConverter"/>
    </Window.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="УПРАВЛЕНИЕ ПОЛЬЗОВАТЕЛЯМИ" 
                   FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"
                   HorizontalAlignment="Center" Margin="0,0,0,15"/>

        <GroupBox Grid.Row="1" Header="Добавить нового пользователя" 
                  Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="Bold" Margin="0,0,0,10"
                  BorderBrush="{DynamicResource BorderBrush}">
            <StackPanel Margin="10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,5,0">
                        <TextBlock Text="Email:" Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBox x:Name="NewEmailTextBox" Height="28"
                                 Background="{DynamicResource SurfaceBrush}" Foreground="{DynamicResource TextPrimaryBrush}"
                                 BorderBrush="{DynamicResource BorderBrush}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="0,0,5,0">
                        <TextBlock Text="Пароль:" Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBox x:Name="NewPasswordTextBox" Height="28"
                                 Background="{DynamicResource SurfaceBrush}" Foreground="{DynamicResource TextPrimaryBrush}"
                                 BorderBrush="{DynamicResource BorderBrush}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Margin="0,0,5,0">
                        <TextBlock Text="Роль:" Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <ComboBox x:Name="NewRoleCombo" Height="28"
                                  Background="White" Foreground="#2D004D"
                                  BorderBrush="{DynamicResource BorderBrush}">
                            <ComboBoxItem Content="Полевой инженер" Tag="field_engineer" IsSelected="True"/>
                            <ComboBoxItem Content="Диспетчер" Tag="dispatcher"/>
                            <ComboBoxItem Content="Администратор" Tag="admin"/>
                        </ComboBox>
                    </StackPanel>

                    <Button Grid.Column="3" Content="Создать" Width="80" Height="28"
                            VerticalAlignment="Bottom" Click="CreateUser_Click"
                            Foreground="White" FontWeight="Bold" FontSize="13"
                            BorderThickness="0" Cursor="Hand">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#9B30FF"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="Bd" Background="{TemplateBinding Background}" 
                                                    CornerRadius="6" Padding="8,4">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#7B1FA2"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </StackPanel>
        </GroupBox>

        <DataGrid Grid.Row="2" x:Name="UsersGrid" AutoGenerateColumns="False" 
                  IsReadOnly="True" SelectionMode="Single"
                  Background="{DynamicResource SurfaceBrush}" 
                  BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                  RowBackground="{DynamicResource RowBrush}" 
                  AlternatingRowBackground="{DynamicResource RowAltBrush}"
                  Foreground="{DynamicResource TextPrimaryBrush}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="200"/>
                <DataGridTextColumn Header="Роль" Binding="{Binding Role}" Width="130"/>
                <DataGridTextColumn Header="Последний вход" Binding="{Binding LastSignInFormatted}" Width="150"/>
                <DataGridTextColumn Header="Статус" Width="120">
                    <DataGridTextColumn.Binding>
                        <Binding Path="IsBlocked" Converter="{StaticResource BlockedToStatusConverter}"/>
                    </DataGridTextColumn.Binding>
                </DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
            <Button Content="🔒 Заблокировать" Width="140" Height="32" Margin="5"
                    Click="BlockUser_Click"
                    Foreground="White" FontWeight="Bold" FontSize="13"
                    BorderThickness="0" Cursor="Hand">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="#E53935"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Bd" Background="{TemplateBinding Background}" 
                                            CornerRadius="6" Padding="8,4">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#C62828"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
            </Button>

            <Button Content="🔓 Разблокировать" Width="140" Height="32" Margin="5"
                    Click="UnblockUser_Click"
                    Foreground="White" FontWeight="Bold" FontSize="13"
                    BorderThickness="0" Cursor="Hand">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="#4CAF50"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Bd" Background="{TemplateBinding Background}" 
                                            CornerRadius="6" Padding="8,4">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#388E3C"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
            </Button>

            <Button Content="🔑 Сбросить пароль" Width="150" Height="32" Margin="5"
                    Click="ResetPassword_Click"
                    Foreground="White" FontWeight="Bold" FontSize="13"
                    BorderThickness="0" Cursor="Hand">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="#FF9800"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Bd" Background="{TemplateBinding Background}" 
                                            CornerRadius="6" Padding="8,4">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#F57C00"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
            </Button>

            <Button Content="🗑 Удалить" Width="120" Height="32" Margin="5"
                    Click="DeleteUser_Click"
                    Foreground="White" FontWeight="Bold" FontSize="13"
                    BorderThickness="0" Cursor="Hand">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="#D32F2F"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Bd" Background="{TemplateBinding Background}" 
                                            CornerRadius="6" Padding="8,4">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#B71C1C"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
            </Button>
        </StackPanel>
    </Grid>
</Window>