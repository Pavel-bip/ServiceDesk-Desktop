<Window x:Class="ServiceDeskDesktop.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Вход в систему" Height="350" Width="400"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="{DynamicResource BackgroundBrush}" Icon="/Views/upscalemedia-transformed.png">
    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="📡 РОСТЕЛЕКОМ" FontSize="20" FontWeight="Bold" 
                       Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center"/>
            <TextBlock Text="Сервисное обслуживание" FontSize="13" 
                       Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center" Margin="0,5,0,0"/>
        </StackPanel>

        <StackPanel Grid.Row="1">
            <TextBlock Text="Email:" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,5,0,0"/>
            <TextBox x:Name="EmailTextBox" Height="30" Margin="0,0,0,10"
                     BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                     Background="{DynamicResource SurfaceBrush}" Foreground="{DynamicResource TextPrimaryBrush}"/>

            <TextBlock Text="Пароль:" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,5,0,0"/>
            <PasswordBox x:Name="PasswordBox" Height="30" Margin="0,0,0,15"
                         BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                         Background="{DynamicResource SurfaceBrush}" Foreground="{DynamicResource TextPrimaryBrush}"/>

            <TextBlock x:Name="ErrorText" Foreground="Red" FontWeight="Bold" 
                       HorizontalAlignment="Center" Visibility="Collapsed"/>
        </StackPanel>

        <Button Grid.Row="2" Content="Войти" Height="38"
                Click="Login_Click"
                Foreground="White" FontWeight="Bold" FontSize="14"
                BorderThickness="0" Cursor="Hand">
            <Button.Style>
                <Style TargetType="Button">
                    <Setter Property="Background" Value="#9B30FF"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" Background="{TemplateBinding Background}" 
                                        CornerRadius="8" Padding="10,5">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#7B1FA2"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </Button.Style>
        </Button>
    </Grid>
</Window>