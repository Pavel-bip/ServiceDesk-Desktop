<Window x:Class="ServiceDeskDesktop.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:ServiceDeskDesktop.Converters"
        Title="Диспетчер заявок — Ростелеком" Height="780" Width="1331"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BackgroundBrush}" Icon="/Views/upscalemedia-transformed.png">

    <Window.Resources>
        <converters:BoolToColorConverter x:Key="BoolToColorConverter"/>
        <Style TargetType="ComboBox">
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Шапка -->
        <Grid Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="📡 УПРАВЛЕНИЕ ЗАЯВКАМИ НА ОБСЛУЖИВАНИЕ" 
                       FontSize="22" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
            <TextBlock x:Name="UserInfoText" VerticalAlignment="Center" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="Bold" Margin="20,0,0,0"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <Ellipse x:Name="OnlineIndicator" Width="12" Height="12" Fill="Red" 
                         VerticalAlignment="Center" Margin="0,0,5,0"/>
                <TextBlock x:Name="StatusText" Text="Офлайн" VerticalAlignment="Center" 
                           Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="Bold" Margin="0,0,10,0"
                           MouseLeftButtonDown="StatusText_MouseLeftButtonDown" Cursor="Hand"/>

                <Button x:Name="ThemeButton" Content="🌙" Width="35" Height="35" Margin="0,0,10,0"
                        Click="ThemeToggle_Click"
                        Foreground="White" FontWeight="Bold" FontSize="16"
                        BorderThickness="0" Cursor="Hand" ToolTip="Переключить тему">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#6A0DAD"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bd" Background="{TemplateBinding Background}" 
                                                CornerRadius="20" Padding="5">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#4B0082"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>

                <Button Content="🚪 Выход" Width="90" Height="35"
                        Click="ExitButton_Click"
                        Foreground="White" FontWeight="Bold" FontSize="13"
                        BorderThickness="0" Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#FF6B6B"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bd" Background="{TemplateBinding Background}" 
                                                CornerRadius="8" Padding="10,5">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#E53935"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </Grid>

        <Rectangle Grid.Row="0" Height="2" Fill="{DynamicResource BorderBrush}" VerticalAlignment="Bottom" Opacity="0.3"/>

        <!-- Панель инструментов -->
        <Grid Grid.Row="1" Margin="0,10,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <Button Content="➕ Добавить" Width="103" Height="35" Margin="3"
                        Click="AddButton_Click"
                        Foreground="{DynamicResource TextOnPrimaryBrush}" FontWeight="Bold" FontSize="13"
                        BorderThickness="0" Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="{DynamicResource PrimaryBrush}"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="8" Padding="10,5">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#7B1FA2"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
                <Button Content="✏ Редактировать" Width="137" Height="35" Margin="3"
                        Click="EditButton_Click"
                        Foreground="{DynamicResource TextOnPrimaryBrush}" FontWeight="Bold" FontSize="13"
                        BorderThickness="0" Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="{DynamicResource PrimaryBrush}"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="8" Padding="10,5">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#7B1FA2"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
                <Button Content="🗑 Удалить" Width="100" Height="35" Margin="3"
                        Click="DeleteButton_Click"
                        Foreground="{DynamicResource TextOnPrimaryBrush}" FontWeight="Bold" FontSize="13"
                        BorderThickness="0" Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="{DynamicResource PrimaryBrush}"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="8" Padding="10,5">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#7B1FA2"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>

            <Rectangle Grid.Column="1" Width="2" Fill="{DynamicResource BorderBrush}" Margin="15,5" Opacity="0.5"/>

            <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock Text="⌕" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" 
           VerticalAlignment="Center" Margin="0,0,5,0"/>
                <TextBox x:Name="SearchTextBox" Width="233" Height="30"
                         TextChanged="SearchTextBox_TextChanged"
                         BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                         VerticalContentAlignment="Center" FontSize="14"
                         Background="{DynamicResource SurfaceBrush}"
                         Foreground="{DynamicResource TextPrimaryBrush}"/>
                <TextBlock Text="Статус:" VerticalAlignment="Center" Margin="10,0,5,0" 
                           Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="Bold"/>
                <ComboBox x:Name="StatusFilter" Width="100" Height="30"
          Background="White" Foreground="#2D004D"
          BorderBrush="#9B30FF" BorderThickness="1" FontSize="13">
                    <ComboBoxItem Content="Все"/>
                    <ComboBoxItem Content="Новая"/>
                    <ComboBoxItem Content="Назначена"/>
                    <ComboBoxItem Content="В работе"/>
                    <ComboBoxItem Content="Выполнена"/>
                    <ComboBoxItem Content="Отложена"/>
                    <ComboBoxItem Content="Отменена"/>
                </ComboBox>
                <TextBlock Text="Приоритет:" VerticalAlignment="Center" Margin="10,0,5,0" 
                           Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="Bold"/>
                <ComboBox x:Name="PriorityFilter" Width="100" Height="30"
          Background="White" Foreground="#2D004D"
          BorderBrush="#9B30FF" BorderThickness="1" FontSize="13">
                    <ComboBoxItem Content="Все"/>
                    <ComboBoxItem Content="Плановый"/>
                    <ComboBoxItem Content="Срочный"/>
                    <ComboBoxItem Content="Аварийный"/>
                </ComboBox>
            </StackPanel>

            <StackPanel Grid.Column="3" Orientation="Horizontal">
                <Button Content="📋 Отчёт" Width="90" Height="32" Margin="2"
                        Click="ReportButton_Click"
                        Foreground="{DynamicResource TextOnPrimaryBrush}" FontWeight="Bold" FontSize="13"
                        BorderThickness="0" Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#6A0DAD"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="6" Padding="8,4">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#4B0082"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
                <Button Content="📈 Аналитика" Width="113" Height="32" Margin="2"
                        Click="AnalyticsButton_Click"
                        Foreground="{DynamicResource TextOnPrimaryBrush}" FontWeight="Bold" FontSize="13"
                        BorderThickness="0" Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#6A0DAD"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="6" Padding="8,4">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#4B0082"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
                <Button x:Name="AdminButton" Content="👥 Админ" Width="87" Height="32" Margin="2"
                        Click="AdminButton_Click"
                        Foreground="{DynamicResource TextOnPrimaryBrush}" FontWeight="Bold" FontSize="13"
                        BorderThickness="0" Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#6A0DAD"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="6" Padding="8,4">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#4B0082"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </Grid>

        <Rectangle Grid.Row="1" Height="2" Fill="{DynamicResource BorderBrush}" VerticalAlignment="Bottom" Opacity="0.3"/>

        <!-- Таблица -->
        <DataGrid Grid.Row="2" x:Name="RequestsGrid" Margin="0,10,0,0"
                  AutoGenerateColumns="False" IsReadOnly="True"
                  SelectionMode="Single" SelectionChanged="RequestsGrid_SelectionChanged"
                  Background="{DynamicResource SurfaceBrush}" 
                  BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                  RowBackground="{DynamicResource RowBrush}" 
                  AlternatingRowBackground="{DynamicResource RowAltBrush}"
                  GridLinesVisibility="Horizontal" FontSize="13"
                  Foreground="{DynamicResource TextPrimaryBrush}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="110"/>
                <DataGridTextColumn Header="Клиент/счет" Binding="{Binding ClientInfo}" Width="180"/>
                <DataGridTextColumn Header="Адрес" Binding="{Binding Address}" Width="220"/>
                <DataGridTextColumn Header="Телефон" Binding="{Binding Phone}" Width="130"/>
                <DataGridTextColumn Header="Тип оборудования" Binding="{Binding EquipmentType}" Width="150"/>
                <DataGridTextColumn Header="Статус" Binding="{Binding Status}" Width="110"/>
                <DataGridTextColumn Header="Приоритет" Binding="{Binding Priority}" Width="110"/>
                <DataGridTextColumn Header="Дата" Binding="{Binding CreatedAtFormatted}" Width="150"/>
            </DataGrid.Columns>
        </DataGrid>

        <StatusBar Grid.Row="3" Margin="0,5,0,0" Background="{DynamicResource StatusBarBrush}">
            <StatusBarItem>
                <TextBlock x:Name="RecordCount" Text="Записей: 0" 
                           Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="Bold"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>